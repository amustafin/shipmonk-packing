{
    "name": "amustafin/shipmonk-packing",
    "description": "Testing day application stub",
    "require": {
        "ext-pdo": "*",
        "ext-json": "*",
        "php": ">=8.4",
        "psr/http-message": "2.*",
        "guzzlehttp/psr7": "2.*",
        "doctrine/orm": "3.*",
        "symfony/cache": "7.*",
        "symfony/var-exporter": "^7.0",
        "guzzlehttp/guzzle": "^7.9",
        "php-di/php-di": "^7.1",
        "symfony/yaml": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "prepare-db": "bin/doctrine orm:schema-tool:create && bin/doctrine dbal:run-sql \"$(cat data/packaging-data.sql)\"",
        "runSample": "php run.php \"$(cat sample.json)\"",
        "test": "vendor/bin/phpunit tests/Tests",
        "test-coverage": "vendor/bin/phpunit tests/ --coverage-html coverage",
        "cs": [
            "@codestyle"
        ],
        "cs-fix": [
            "@codestyle-fix"
        ],
        "codestyle": "vendor/bin/ecs check",
        "codestyle-fix": "vendor/bin/ecs check --fix",
        "phpstan": [
            "@phpstan-clear-cache",
            "@phpstan-analyse"
        ],
        "phpstan-clear-cache": "vendor/bin/phpstan clear-result-cache",
        "phpstan-analyse": "vendor/bin/phpstan analyse -c config.phpstan.neon --memory-limit=1G",
        "phpstan-update-baseline": [
            "@phpstan-clear-cache",
            "vendor/bin/phpstan analyse -c config.phpstan.neon --memory-limit=1G --generate-baseline"
        ]
    },
    "require-dev": {
        "symplify/easy-coding-standard": "^13.0",
        "phpstan/phpstan": "^2.1",
        "ekino/phpstan-banned-code": "^3.0",
        "phpunit/phpunit": "^12.5"
    }
}
