{
    "name": "amustafin/shipmonk-packing",
    "description": "Testing day application stub",
    "require": {
        "ext-pdo": "*",
        "ext-json": "*",
        "php": ">=8.4",
        "psr/http-message": "2.*",
        "guzzlehttp/psr7": "2.*",
        "doctrine/orm": "3.*",
        "symfony/cache": "7.*",
        "guzzlehttp/guzzle": "^7.9",
        "php-di/php-di": "^7.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "prepare-db": "bin/doctrine orm:schema-tool:create && bin/doctrine dbal:run-sql \"$(cat data/packaging-data.sql)\"",
        "runSample": "php run.php \"$(cat sample.json)\"",
        "cs": [
            "@codestyle"
        ],
        "cs-fix": [
            "@codestyle-fix"
        ],
        "codestyle": "vendor/bin/ecs check",
        "codestyle-fix": "vendor/bin/ecs check --fix"
    },
    "require-dev": {
        "symplify/easy-coding-standard": "^13.0"
    }
}
